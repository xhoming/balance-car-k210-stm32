#include "app_k210_cmd.h"

static uint8_t s_cmd_last_flags = 0;
static int16_t s_cmd_speed = 0;
static int8_t s_cmd_dir = 1;
static int16_t s_cmd_turn = 0;
static uint8_t s_cmd_buf[6] = {0};
static uint8_t s_cmd_idx = 0;
static uint8_t s_cmd_len = 0;
static uint8_t s_cmd_new = 0;
static uint8_t s_ctrl_running = 0;

float Car_Turn_Kp = 64.0f;
float Car_Turn_Ki = 0.11f;
float Car_Turn_Kd = 0.7f;

static float s_heading = 0.0f;
static float s_heading_zero = 0.0f;
static float s_target_heading = 0.0f;
static float s_turn_integral = 0.0f;
static float s_last_error = 0.0f;
static float s_last_gyro = 0.0f;
static uint8_t s_calib_done = 0;
static uint8_t s_stable_cnt = 0;

static float K210_Angle_Wrap(float angle)
{
    while (angle > 180.0f) angle -= 360.0f;
    while (angle < -180.0f) angle += 360.0f;
    return angle;
}

void K210_Command_Stop(void)
{
    s_cmd_speed = 0;
    s_cmd_turn = 0;
    s_ctrl_running = 0;
    s_target_heading = K210_Angle_Wrap(s_heading - s_heading_zero);
    s_turn_integral = 0.0f;
    s_last_error = 0.0f;
    Move_X = 0;
    Move_Z = 0;
    Car_Target_Velocity = 0;
    Car_Turn_Amplitude_speed = 0;
    g_newcarstate = enSTOP;
    Velocity_PI_Reset();
}

uint8_t K210_Command_IsRunning(void)
{
    return s_ctrl_running;
}

void Car_Diff_SetZero(void)
{
    s_heading_zero = s_heading;
    s_cmd_turn = 0;
    s_target_heading = 0.0f;
    s_turn_integral = 0.0f;
    s_last_error = 0.0f;
    s_calib_done = 1;
    s_stable_cnt = 0;
}

static int16_t K210_Command_Clamp(int16_t value, int16_t low, int16_t high)
{
    if (value < low) return low;
    if (value > high) return high;
    return value;
}

static void K210_Command_Apply(uint8_t flags)
{
    uint8_t left     = flags & K210_CMD_LEFT;
    uint8_t right    = flags & K210_CMD_RIGHT;
    uint8_t speed_up = flags & K210_CMD_SPEED_UP;
    uint8_t speed_dn = flags & K210_CMD_SPEED_DOWN;
    uint8_t forward  = flags & K210_CMD_FORWARD;
    uint8_t backward = flags & K210_CMD_BACKWARD;

    s_cmd_last_flags = flags;

    if (flags == 0) {
        K210_Command_Stop();
        return;
    }

    if (!s_ctrl_running) {
        Car_Diff_SetZero();
        s_ctrl_running = 1;
        Stop_Flag = 0;
    }

    if (backward) s_cmd_dir = -1;
    if (forward)  s_cmd_dir =  1;

    if (speed_up) {
        s_cmd_speed += K210_CMD_ACCEL_STEP;
        if (s_cmd_speed > K210_CMD_SPEED_MAX) s_cmd_speed = K210_CMD_SPEED_MAX;
    }

    if (speed_dn) {
        s_cmd_speed -= K210_CMD_DECEL_STEP;
        if (s_cmd_speed < 0) s_cmd_speed = 0;
    }

    if (left && !right) {
        s_cmd_turn -= K210_CMD_TURN_STEP;
    } else if (right && !left) {
        s_cmd_turn += K210_CMD_TURN_STEP;
    }

    if (s_cmd_turn >  K210_CMD_TURN_MAX) s_cmd_turn =  K210_CMD_TURN_MAX;
    if (s_cmd_turn < -K210_CMD_TURN_MAX) s_cmd_turn = -K210_CMD_TURN_MAX;

    g_newcarstate = enSTOP;
    Move_X = s_cmd_dir * s_cmd_speed;
    Move_Z = 0;
    Car_Target_Velocity = s_cmd_speed;
    Car_Turn_Amplitude_speed = K210_CMD_TURN_MAX;
}

static void K210_Control_Apply(int8_t speed, int8_t turn, uint8_t dir)
{
    int16_t speed_cmd;
    int16_t turn_cmd;

    if (dir == K210_CTRL_MODE_STOP) {
        K210_Command_Stop();
        s_cmd_last_flags = 0;
        return;
    }

    if (!s_ctrl_running) {
        Car_Diff_SetZero();
        s_ctrl_running = 1;
        Stop_Flag = 0;
    }

    speed_cmd = K210_Command_Clamp(speed, -K210_CTRL_SPEED_MAX,
                                   K210_CTRL_SPEED_MAX);
    turn_cmd = K210_Command_Clamp(turn, -K210_CTRL_TURN_MAX,
                                  K210_CTRL_TURN_MAX);

    if (dir == 2) {
        s_cmd_dir = -1;
    } else if (speed_cmd < 0) {
        s_cmd_dir = -1;
    } else {
        s_cmd_dir = 1;
    }

    s_cmd_speed = (speed_cmd >= 0) ? speed_cmd : -speed_cmd;
    s_cmd_turn += (int16_t)(turn_cmd * K210_CTRL_TURN_SCALE);
    if (s_cmd_turn >  K210_TARGET_ANGLE_MAX) s_cmd_turn =  K210_TARGET_ANGLE_MAX;
    if (s_cmd_turn < -K210_TARGET_ANGLE_MAX) s_cmd_turn = -K210_TARGET_ANGLE_MAX;
    s_cmd_last_flags = 0;

    g_newcarstate = enSTOP;
    Move_X = s_cmd_dir * s_cmd_speed;
    Move_Z = 0;
    Car_Target_Velocity = s_cmd_speed;
    Car_Turn_Amplitude_speed = K210_CTRL_TURN_MAX * K210_CTRL_TURN_SCALE;
}

void Deal_K210_Command(uint8_t recv_msg)
{
    if (recv_msg == K210_CMD_HEAD && s_cmd_idx == 0) {
        s_cmd_idx = 0;
        s_cmd_buf[s_cmd_idx++] = recv_msg;
    } else if (s_cmd_idx > 0 && s_cmd_idx < sizeof(s_cmd_buf)) {
        s_cmd_buf[s_cmd_idx++] = recv_msg;
        if (s_cmd_idx == 4 && s_cmd_buf[3] == K210_CMD_TAIL) {
            s_cmd_len = 4;
            s_cmd_new = 1;
            s_cmd_idx = 0;
        } else if (s_cmd_idx == 6 && s_cmd_buf[5] == K210_CMD_TAIL) {
            s_cmd_len = 6;
            s_cmd_new = 1;
            s_cmd_idx = 0;
        } else if (s_cmd_idx >= sizeof(s_cmd_buf)) {
            s_cmd_idx = 0;
            s_cmd_len = 0;
        }
    } else {
        s_cmd_idx = 0;
    }
}

void K210_Command_Task(void)
{
    uint8_t hdr;
    uint8_t flags;
    uint8_t chk;
    uint8_t ftr;
    int8_t speed;
    int8_t turn;
    uint8_t ctrl_mode;

    if (!s_cmd_new) {
        return;
    }
    s_cmd_new = 0;

    hdr = s_cmd_buf[0];

    if (s_cmd_len == 6) {
        speed = (int8_t)s_cmd_buf[1];
        turn = (int8_t)s_cmd_buf[2];
        ctrl_mode = s_cmd_buf[3];
        chk = s_cmd_buf[4];
        ftr = s_cmd_buf[5];

        if (hdr != K210_CMD_HEAD || ftr != K210_CMD_TAIL ||
                chk != (uint8_t)(s_cmd_buf[1] + s_cmd_buf[2] + ctrl_mode)) {
            return;
        }

        K210_Control_Apply(speed, turn, ctrl_mode);
    } else if (s_cmd_len == 4) {
        flags = s_cmd_buf[1];
        chk = s_cmd_buf[2];
        ftr = s_cmd_buf[3];

        if (hdr != K210_CMD_HEAD || ftr != K210_CMD_TAIL || chk != flags) {
            return;
        }

        K210_Command_Apply(flags);
    }
    s_cmd_len = 0;
}

uint8_t K210_Command_Last_Flags(void)
{
    return s_cmd_last_flags;
}

float K210_Command_Current_Speed(void)
{
    return (float)s_cmd_speed;
}

float K210_Command_Current_Turn(void)
{
    return (float)s_cmd_turn;
}

int8_t K210_Command_Current_Dir(void)
{
    return s_cmd_dir;
}

void Car_Diff_Turn_Reset(void)
{
    s_heading = 0.0f;
    s_heading_zero = 0.0f;
    s_target_heading = 0.0f;
    s_turn_integral = 0.0f;
    s_last_error = 0.0f;
    s_last_gyro = 0.0f;
    s_calib_done = 0;
    s_stable_cnt = 0;
    s_ctrl_running = 0;
}

uint8_t Car_Diff_IsLocked(void)
{
    return s_calib_done;
}

float Car_Diff_Heading(void)
{
    return K210_Angle_Wrap(s_heading - s_heading_zero);
}

void Car_Diff_Turn(float gyro_turn, int enc_left, int enc_right)
{
    float diff;
    float target;
    float actual;
    float error;
    int turn_pwm;

    (void)enc_left;
    (void)enc_right;

    if (!s_ctrl_running) {
        return;
    }

    s_heading = K210_Angle_Wrap(s_heading + gyro_turn * 0.005f);

    if (!s_calib_done) {
        diff = gyro_turn - s_last_gyro;
        if (diff < 0.0f) diff = -diff;
        s_last_gyro = gyro_turn;

        if (diff < 2.0f) {
            s_stable_cnt++;
            if (s_stable_cnt >= 20) {
                s_heading_zero = s_heading;
                s_turn_integral = 0.0f;
                s_last_error = 0.0f;
                s_calib_done = 1;
                open_beep(30);
            }
        } else {
            s_stable_cnt = 0;
        }
        return;
    }

    actual = K210_Angle_Wrap(s_heading - s_heading_zero);
    target = (float)s_cmd_turn;
    if (target > K210_TARGET_ANGLE_MAX) target = K210_TARGET_ANGLE_MAX;
    if (target < -K210_TARGET_ANGLE_MAX) target = -K210_TARGET_ANGLE_MAX;
    target = K210_Angle_Wrap(target);
    s_target_heading = K210_Angle_Wrap(s_target_heading +
                       K210_Angle_Wrap(target - s_target_heading) *
                       (1.0f - K210_ANGLE_SMOOTH));
    target = s_target_heading;
    error = K210_Angle_Wrap(actual - target);

    s_turn_integral += error;
    if (s_turn_integral > 2000.0f) s_turn_integral = 2000.0f;
    if (s_turn_integral < -2000.0f) s_turn_integral = -2000.0f;

    if ((error > 0.0f && s_last_error < 0.0f) ||
        (error < 0.0f && s_last_error > 0.0f)) {
        s_turn_integral = 0.0f;
    }
    s_last_error = error;

    turn_pwm = (int)(error * Car_Turn_Kp)
             + (int)(s_turn_integral * Car_Turn_Ki)
             - (int)(gyro_turn * Car_Turn_Kd);

    Motor_Left = PWM_Limit(Motor_Left + turn_pwm, 2600, -2600);
    Motor_Right = PWM_Limit(Motor_Right - turn_pwm, 2600, -2600);
}
